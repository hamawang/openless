{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenLess",
  "version": "1.1.3",
  "identifier": "com.openless.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenLess",
        "width": 1240,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "shadow": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": true
      },
      {
        "label": "capsule",
        "url": "index.html?window=capsule",
        "title": "OpenLess Capsule",
        "width": 220,
        "height": 96,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "center": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "entitlements": "Entitlements.plist"
    }
  }
}
